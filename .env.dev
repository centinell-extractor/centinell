# .env.dev - Para desarrollo local con SQLite
# Este archivo es SOLO para desarrollo. No usar en producción.
# IMPORTANTE: Este archivo DEBE versionarse como referencia para desarrollo local.

# ========== BASE DE DATOS LOCAL (SQLite) ==========
# SQLite se crea automáticamente en centinell_dev.db
DATABASE_URL="sqlite+aiosqlite:///./centinell_dev.db"


# ========== OpenAI API (OPCIONAL para desarrollo) ==========
# Si quieres probar con LLM real, descomenta y agrega tu clave
# OPENAI_API_KEY=sk-...


# ========== CONFIGURACIÓN DEL ENTORNO DE DESARROLLO ==========

# Límites relajados para desarrollo
MAX_DOCUMENT_SIZE_MB=50
LLM_TIMEOUT_SECONDS=30
LLM_RETRY_ATTEMPTS=2
LLM_RETRY_DELAY_SECONDS=1
MAX_CONCURRENT_EXTRACTIONS=5


# Notas:
# - Al activar SQLite, las tablas se crean automáticamente en centinell_dev.db
# - Si necesitas resetear DB local: rm centinell_dev.db
# - Para producción, copia .env.example a .env y completa con valores reales
