# Variables de entorno de Centinell
# Copia este archivo a .env y rellena los valores reales.
# IMPORTANTE: .env NUNCA debe versionarse. Usa .gitignore.

# ========== REQUERIDAS ==========

# Base de datos PostgreSQL (con asyncpg para async)
DATABASE_URL="postgresql+asyncpg://usuario:password@host:5432/base_de_datos"

# OpenAI API Key (generar en https://platform.openai.com/api-keys)
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"


# ========== CONFIGURACIÓN DE PRODUCCIÓN (Opcional) ==========

# Límite de tamaño de documento en MB (default: 5)
MAX_DOCUMENT_SIZE_MB=5

# Timeout para llamadas a LLM en segundos (default: 120, max: 300)
LLM_TIMEOUT_SECONDS=120

# Número de reintentos para llamadas LLM que fallan (default: 3)
LLM_RETRY_ATTEMPTS=3

# Delay inicial en segundos entre reintentos - usa exponential backoff (default: 1)
LLM_RETRY_DELAY_SECONDS=1

# Máximo de extracciones simultáneas (default: 10)
MAX_CONCURRENT_EXTRACTIONS=10